{
  "name": "ink-studio",
  "version": "0.13.0",
  "description": "Obsidian plugin: handwriting/stylus note-taking with pressure-sensitive vector ink, built for Android tablets with a stylus.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "handwriting",
    "stylus",
    "ink",
    "notes",
    "annotation"
  ],
  "author": "Mohammadreza Rashidian",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "perfect-freehand": "^1.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "hersheytext": "^2.0.0",
    "lucide-static": "^1.24.0",
    "obsidian": "^1.13.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
